(7, (SELECT id FROM modulos WHERE nombre='reportes'),    (SELECT id FROM acciones WHERE nombre='descargar'));

-- Agregar módulo plantillas
INSERT INTO modulos (nombre) VALUES ('plantillas');

-- Agregar acciones
INSERT INTO acciones (nombre) VALUES ('leer'), ('crear'), ('editar')
ON DUPLICATE KEY UPDATE nombre = nombre;

-- ADMIN (rol_id=1): leer, crear, editar
INSERT INTO rol_permisos (rol_id, modulo_id, accion_id) VALUES
(1, 14, 2),  -- leer
(1, 14, 1),  -- crear
(1, 14, 10), -- editar
-- FUNCIONARIO_CERTIFICACION (rol_id=2): leer, crear, editar
(2, 14, 2),  -- leer
(2, 14, 1),  -- crear
(2, 14, 10); -- editar

-- Asignar permiso descargar de solicitudes a ADMIN y FUNCIONARIO_CERTIFICACION
INSERT INTO rol_permisos (rol_id, modulo_id, accion_id)
SELECT r.id, m.id, a.id
FROM roles r, modulos m, acciones a
WHERE r.id IN (1, 2)
AND m.nombre = 'solicitudes'
AND a.nombre = 'descargar'
ON DUPLICATE KEY UPDATE rol_id = rol_id;